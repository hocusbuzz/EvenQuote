# ────────────────────────────────────────────────────────────────────
# EvenQuote — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real keys.
# ────────────────────────────────────────────────────────────────────

# ─── Phase 1: Supabase ─────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...          # public, safe in browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...              # SERVER ONLY — bypasses RLS

# ─── Phase 2: Auth ─────────────────────────────────────────────────
# Google OAuth is feature-flagged. Leave as 'false' until you've:
#   1. Created OAuth 2.0 credentials in Google Cloud Console
#   2. Enabled the Google provider in Supabase (Auth → Providers) with
#      the client ID and secret
#   3. Added https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback as
#      an authorized redirect URI in Google Cloud
# Then flip to 'true' and the "Continue with Google" button appears.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# The client ID/secret themselves live in the Supabase dashboard, not
# here — Supabase handles the OAuth handshake on our behalf. These
# vars are only here as a reference for what you'll need in Google Cloud:
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Phase 5: Stripe ───────────────────────────────────────────────
# From Stripe dashboard → Developers → API keys. Use test keys in dev.
STRIPE_SECRET_KEY=sk_test_...
# From Stripe dashboard → Developers → Webhooks → (your endpoint) →
# "Signing secret". Local dev: get this from `stripe listen`.
STRIPE_WEBHOOK_SECRET=whsec_...
# Not used by the server — reserved for a future client-side <StripeProvider>.
# Safe in the browser bundle.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Not needed for Phase 5 (inline price_data). Reserved for when we
# move to catalog-based pricing.
# STRIPE_PRICE_ID_QUOTE_REQUEST=

# ─── Phase 6: Business data (Google Places) ────────────────────────
# Create a Google Cloud project → enable "Places API (New)" → create
# an API key. Lock it down to your app's IPs in production.
GOOGLE_PLACES_API_KEY=

# ─── Phase 6: Vapi (outbound calls + webhook) ──────────────────────
# From vapi.ai dashboard. If any of these are blank, the call engine
# runs in "simulation mode": it still inserts calls rows and updates
# status, but doesn't place real calls. Good for local dev.
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
# Optional. The inbound-callback assistant — used by /api/vapi/inbound-callback
# when a customer presses-to-callback after an outbound. The
# scripts/patch-vapi-tunnel-url.ts helper updates this assistant's
# server.url alongside the outbound assistant's. Leave unset if you
# don't have an inbound assistant configured.
VAPI_INBOUND_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
# Set the same value in Vapi's webhook config AND here. The webhook
# route checks the x-vapi-secret header against this.
VAPI_WEBHOOK_SECRET=

# Optional fallback phone number used when the Vapi number pool is
# empty AND VAPI_PHONE_NUMBER_ID is unset. Preferred form: +E.164.
# Only relevant if you're running on a pre-pool deploy; with the
# 0007 vapi_number_pool migration applied you shouldn't need this.
# VAPI_CALLBACK_NUMBER=

# How many businesses to call per paid quote_request. Default 5.
# CALL_BATCH_SIZE=5

# ─── Phase 6: Quote extraction (optional but recommended) ─────────
# If set, the Vapi webhook runs a tool-use extraction against
# transcripts that don't already have Vapi-side structured data.
# If unset, the call still completes but no quote row is inserted.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Default model. Haiku is fast + cheap and plenty accurate for this
# structured-extraction task. Swap in sonnet/opus for harder transcripts.
ANTHROPIC_EXTRACTION_MODEL=claude-haiku-4-5-20251001

# ─── Phase 9: Resend ────────────────────────────────────────────────
# RESEND_API_KEY=
# RESEND_FROM is a "Display Name <addr@domain>" or bare email; defaults
# to "EvenQuote <reports@evenquote.com>" if unset.
# RESEND_FROM=
# Optional support inbox surfaced in zero-quote refund emails.
# EVENQUOTE_SUPPORT_EMAIL=

# ─── Phase 6.1: Twilio inbound SMS ─────────────────────────────────
# HMAC-SHA1 validation token used by app/api/twilio/sms/route.ts.
# REQUIRED in production — if unset, the route hard-refuses with 500
# so misconfig never silently drops customer-facing SMS quotes.
TWILIO_AUTH_TOKEN=

# ─── App config ────────────────────────────────────────────────────
# IMPORTANT for Phase 5: success_url/cancel_url/magic-link callbacks
# are all built from this. In production set to your canonical https URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Ops: Maintenance gate ─────────────────────────────────────────
# Flip MAINTENANCE_MODE to 'true' in Vercel to hide the public site
# behind the /maintenance page. Webhooks + cron endpoints keep working
# so Stripe/Vapi retries still land and pg_cron can fire reports.
# Optional bypass: append ?preview=<token> to any URL to set a short-
# lived cookie that lets the operator browse normally.
MAINTENANCE_MODE=false
MAINTENANCE_PREVIEW_TOKEN=

# ─── Ops: Content Security Policy (Round 9) ────────────────────────
# CSP_NONCE_ENABLED — when 'true', middleware emits a per-request
#   nonce + Content-Security-Policy-Report-Only header pointing
#   /api/csp-report. Default off. Flip to 'true' to begin the 7-day
#   report-only window per docs/CSP_PLAN.md.
# CSP_ENFORCE — when 'true' AND CSP_NONCE_ENABLED is also true, the
#   header changes from Report-Only to enforcing. Do NOT flip until
#   the report-only window comes back clean and <Script> tags in
#   app/layout.tsx have been wired with nonce={nonce} props.
# LOG_FULL_CSP — when 'true', /api/csp-report logs the full violation
#   payload (URLs, source files, line numbers). Off by default to
#   avoid leaking guest-token URLs into log streams. Flip to 'true'
#   only while actively debugging a violation.
# CSP_VIOLATIONS_PERSIST — when 'true', /api/csp-report ALSO writes
#   curated violation columns to the csp_violations table. Default
#   off. Flip to 'true' only inside a deliberate collection window
#   (see docs/CSP_PLAN.md); the table is PII-adjacent and shouldn't
#   collect on normal days.
CSP_NONCE_ENABLED=false
CSP_ENFORCE=false
LOG_FULL_CSP=false
CSP_VIOLATIONS_PERSIST=false

# ─── Ops: Observability (pending DSN unlock) ───────────────────────
# SENTRY_DSN — when set, lib/observability/sentry.ts forwards
#   captureException/captureMessage/setUser to @sentry/nextjs. Unset
#   = stub mode (~43 capture sites locked at contract level but
#   no-op at runtime). Flip on once the Sentry project is created.
# SENTRY_TRACES_SAMPLE_RATE — float 0.0–1.0. Default undefined →
#   zero tracing (error capture only).
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=

# ─── Ops: Dev-only auth ────────────────────────────────────────────
# DEV_TRIGGER_TOKEN — optional Layer-2 auth on /api/dev/* routes.
#   Layer-1 is NODE_ENV !== 'production'; this is an additional
#   constant-time-compared secret for team-shared staging. Leave
#   unset on a solo dev laptop. Only consumed in non-prod builds.
# TEST_OVERRIDE_PHONE — +E.164 number that EVERY outbound Vapi call
#   in non-prod routes to, bypassing the business's real phone.
#   Useful for E2E tests against your own handset. Ignored in prod.
# DEV_TRIGGER_TOKEN=
# TEST_OVERRIDE_PHONE=

# ─── Ops: Scripts ──────────────────────────────────────────────────
# ALLOW_PROD_SEED — script-only safety flag. scripts/seed-csp-sample
#   and similar seed scripts refuse to run against a prod Supabase
#   URL unless this is exactly 'true'. Almost never needed.
# ALLOW_PROD_SEED=
#
# SUPABASE_ACCESS_TOKEN — Personal Access Token from
#   https://supabase.com/dashboard/account/tokens. Consumed only by
#   scripts/apply-migration.ts to hit the Management API. Generate
#   one when you need to apply a migration from your laptop, then
#   revoke immediately. NEVER set this in a deployed environment —
#   migrations in prod ship via your CI / supabase db push, not a PAT.
# SUPABASE_ACCESS_TOKEN=
#
# APP_URL — base URL the smoke / e2e scripts target when POSTing to
#   /api/dev/* routes. Defaults to http://localhost:3000. Override
#   when Next.js picks a fallback port (3001, 3002…) because :3000
#   is busy. Example: APP_URL=http://localhost:3001
# APP_URL=
#
# YES_WIPE — confirmation gate for scripts/wipe-quote-data.ts. Must
#   be exactly '1'. The script refuses to run otherwise so a stray
#   `npx tsx` invocation can't accidentally nuke the table. Pre-launch
#   only — never set this in any deployed environment.
# YES_WIPE=
#
# STUCK_PAID_MINUTES / STUCK_CALLING_MINUTES / STUCK_PROCESSING_MINUTES
#   — thresholds (in minutes) for the check-stuck-requests cron
#   watchdog. Defaults: 15 / 25 / 60. Override only if you observe
#   chronic false-positives — e.g. if real Vapi calls regularly take
#   30+ min and 'calling' alerts are nuisance noise. Lowering these
#   makes alerting more sensitive; raising them makes it less.
# STUCK_PAID_MINUTES=15
# STUCK_CALLING_MINUTES=25
# STUCK_PROCESSING_MINUTES=60
