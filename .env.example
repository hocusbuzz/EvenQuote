# ────────────────────────────────────────────────────────────────────
# EvenQuote — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real keys.
# ────────────────────────────────────────────────────────────────────

# ─── Phase 1: Supabase ─────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...          # public, safe in browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...              # SERVER ONLY — bypasses RLS

# ─── Phase 2: Auth ─────────────────────────────────────────────────
# Google OAuth is feature-flagged. Leave as 'false' until you've:
#   1. Created OAuth 2.0 credentials in Google Cloud Console
#   2. Enabled the Google provider in Supabase (Auth → Providers) with
#      the client ID and secret
#   3. Added https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback as
#      an authorized redirect URI in Google Cloud
# Then flip to 'true' and the "Continue with Google" button appears.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# The client ID/secret themselves live in the Supabase dashboard, not
# here — Supabase handles the OAuth handshake on our behalf. These
# vars are only here as a reference for what you'll need in Google Cloud:
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Phase 5: Stripe ───────────────────────────────────────────────
# From Stripe dashboard → Developers → API keys. Use test keys in dev.
STRIPE_SECRET_KEY=sk_test_...
# From Stripe dashboard → Developers → Webhooks → (your endpoint) →
# "Signing secret". Local dev: get this from `stripe listen`.
STRIPE_WEBHOOK_SECRET=whsec_...
# Not used by the server — reserved for a future client-side <StripeProvider>.
# Safe in the browser bundle.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Not needed for Phase 5 (inline price_data). Reserved for when we
# move to catalog-based pricing.
# STRIPE_PRICE_ID_QUOTE_REQUEST=

# ─── Phase 6: Business data (Google Places) ────────────────────────
# Create a Google Cloud project → enable "Places API (New)" → create
# an API key. Lock it down to your app's IPs in production.
GOOGLE_PLACES_API_KEY=

# ─── Phase 6: Vapi (outbound calls + webhook) ──────────────────────
# From vapi.ai dashboard. If any of these are blank, the call engine
# runs in "simulation mode": it still inserts calls rows and updates
# status, but doesn't place real calls. Good for local dev.
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
# Set the same value in Vapi's webhook config AND here. The webhook
# route checks the x-vapi-secret header against this.
VAPI_WEBHOOK_SECRET=

# How many businesses to call per paid quote_request. Default 5.
# CALL_BATCH_SIZE=5

# ─── Phase 6: Quote extraction (optional but recommended) ─────────
# If set, the Vapi webhook runs a tool-use extraction against
# transcripts that don't already have Vapi-side structured data.
# If unset, the call still completes but no quote row is inserted.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Default model. Haiku is fast + cheap and plenty accurate for this
# structured-extraction task. Swap in sonnet/opus for harder transcripts.
ANTHROPIC_EXTRACTION_MODEL=claude-haiku-4-5-20251001

# ─── Phase 9: Resend (reserved) ────────────────────────────────────
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# ─── App config ────────────────────────────────────────────────────
# IMPORTANT for Phase 5: success_url/cancel_url/magic-link callbacks
# are all built from this. In production set to your canonical https URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
